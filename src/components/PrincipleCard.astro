---
import type { Principle } from '@types/principle';

interface Props {
  principle: Principle;
  compact?: boolean;
}

const { principle, compact = false } = Astro.props;

const categoryToTone: Record<Principle['category'], string> = {
  research: 'tone-research',
  content: 'tone-content',
  interaction: 'tone-interaction',
  accessibility: 'tone-accessibility',
  strategy: 'tone-strategy'
};
---

<article class:list={['glass', 'card', categoryToTone[principle.category], { compact }]} transition:name={`principle-${principle.slug}`}>
  <p class="meta">#{String(principle.id).padStart(3, '0')} · {principle.category}</p>
  <h3>{principle.title}</h3>
  <p>{principle.summary}</p>
  <a href={`/principles/${principle.slug}`} class="read-more">Ver detalle →</a>
</article>

<style>
  .card {
    padding: 1rem;
    display: grid;
    gap: 0.7rem;
    border-left: 4px solid transparent;
    transition: transform 220ms ease, box-shadow 220ms ease;
  }

  .card:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 32px -24px #1f293780;
  }

  .meta {
    margin: 0;
    font-size: 0.78rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  h3 {
    margin: 0;
    font-size: 1.05rem;
  }

  p {
    margin: 0;
    color: #404653;
  }

  .read-more {
    margin-top: 0.35rem;
    font-weight: 600;
    color: var(--accent);
  }

  .compact {
    gap: 0.4rem;
  }

  .tone-research { border-left-color: #3b82f6; }
  .tone-content { border-left-color: #f59e0b; }
  .tone-interaction { border-left-color: #8b5cf6; }
  .tone-accessibility { border-left-color: #10b981; }
  .tone-strategy { border-left-color: #ef4444; }
</style>
