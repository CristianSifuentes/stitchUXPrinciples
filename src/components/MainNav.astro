---
interface NavItem {
  href: string;
  label: string;
}

interface Props {
  items: NavItem[];
  currentPath: string;
}

const { items, currentPath } = Astro.props;
---

<nav class="glass nav">
  {items.map((item) => {
    // Conditional styling marks active section based on current route.
    const isActive = currentPath === item.href;
    return (
      <a href={item.href} class:list={["nav-link", { active: isActive }]} transition:name={`nav-${item.label}`}>
        {item.label}
      </a>
    );
  })}
</nav>

<style>
  .nav {
    display: flex;
    gap: 0.25rem;
    padding: 0.35rem;
    position: sticky;
    top: 1rem;
    z-index: 10;
    width: fit-content;
    margin: 1.2rem auto;
  }

  .nav-link {
    padding: 0.55rem 0.9rem;
    border-radius: 0.8rem;
    color: var(--muted);
    transition: 220ms ease;
  }

  .nav-link:hover {
    color: var(--text);
    background: #e8eafd;
  }

  .nav-link.active {
    color: white;
    background: linear-gradient(120deg, var(--brand), var(--accent));
  }
</style>
