---
import BaseLayout from '@layouts/BaseLayout.astro';
import MainNav from '@components/MainNav.astro';
import Hero from '@components/Hero.astro';
import PrincipleCard from '@components/PrincipleCard.astro';
import { featuredPrinciples } from '@data/principles';

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/principles', label: 'Principles' }
];
---

<BaseLayout
  seo={{
    title: 'Astro UX Lab 2026 | Advanced Landing Page',
    description: 'An Astro landing page with view transitions, large-scale static routing, and typed architecture.',
    image: '/social-card.svg'
  }}
>
  <MainNav items={navItems} currentPath={Astro.url.pathname} />
  <Hero
    title="10 Essential UX Principles + Astro Architecture 2026"
    subtitle="An advanced demo with typed components, reusable layouts, animated page transitions, and static generation for 151 dynamic pages."
  />

  <main class="container home-grid">
    <section class="glass statement" transition:name="intro-panel">
      <h2>Modern architecture for powerful static sites</h2>
      <p>
        This project demonstrates Astro as a high-level framework for content, SEO, and visual experience,
        combining prerendered dynamic routes, named transitions, and strict TypeScript composition.
      </p>
      <a class="cta" href="/principles">Explore 151 principles rendered at build time →</a>
    </section>

    <section>
      <h2 class="section-title">Featured Principles</h2>
      <div class="cards">
        {featuredPrinciples.slice(0, 6).map((principle) => <PrincipleCard principle={principle} compact />)}
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .home-grid {
    display: grid;
    gap: 1rem;
    margin-bottom: 4rem;
  }

  .statement {
    padding: 1.2rem;
  }

  .statement h2,
  .section-title {
    margin: 0 0 0.6rem;
  }

  .cta {
    margin-top: 1rem;
    display: inline-block;
    font-weight: 700;
    color: var(--accent);
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 0.8rem;
  }
</style>
