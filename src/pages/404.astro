---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  seo={{
    title: '404 | Page Not Found',
    description: 'The requested route does not exist in Astro UX Lab.',
    image: '/social-card.svg'
  }}
>
  <main class="container not-found">
    <article class="glass box" transition:name="not-found">
      <p>404</p>
      <h1>Page Not Found</h1>
      <p>The URL does not exist or has been moved. You can return home or explore the UX principles.</p>
      <div class="actions">
        <a href="/">Home</a>
        <a href="/principles">Principles</a>
      </div>
    </article>
  </main>
</BaseLayout>

<style>
  .not-found {
    min-height: 70vh;
    display: grid;
    place-items: center;
  }

  .box {
    padding: 1.3rem;
    max-width: 560px;
  }

  .actions {
    display: flex;
    gap: 0.6rem;
  }

  .actions a {
    background: #e9edff;
    padding: 0.5rem 0.8rem;
    border-radius: 0.6rem;
    font-weight: 600;
  }
</style>
