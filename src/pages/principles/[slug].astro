---
import BaseLayout from '@layouts/BaseLayout.astro';
import MainNav from '@components/MainNav.astro';
import { principles } from '@data/principles';

export function getStaticPaths() {
  // Dynamic arguments per URL are mapped here; Astro will generate each page at build time.
  return principles.map((principle) => ({
    params: { slug: principle.slug },
    props: { principle }
  }));
}

const { principle } = Astro.props;
const currentSlug = Astro.params.slug;

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/principles', label: 'Principles' }
];
---

<BaseLayout
  seo={{
    title: `${principle.title} | Astro UX Lab`,
    description: principle.summary,
    image: '/social-card.svg'
  }}
>
  <MainNav items={navItems} currentPath={'/principles'} />

  <main class="container detail" transition:name={`principle-${currentSlug}`}>
    <a href="/principles" class="back">← Back to the list</a>

    <article class="glass panel">
      <p class="id">Dynamic route: /principles/{currentSlug}</p>
      <h1 transition:name="hero-title">{principle.title}</h1>
      <p class="summary">{principle.summary}</p>

      <div class="chips">
        <span class="chip">ID: {principle.id}</span>
        <span class="chip">Category: {principle.category}</span>
        <span class="chip">Prerendered: Yes (build time)</span>
      </div>
    </article>
  </main>
</BaseLayout>

<style>
  .detail {
    padding: 1.2rem 0 3rem;
  }

  .back {
    color: var(--accent);
    font-weight: 600;
  }

  .panel {
    margin-top: 0.9rem;
    padding: 1.2rem;
  }

  .id {
    color: #64748b;
    margin: 0;
  }

  h1 {
    margin: 0.6rem 0;
  }

  .summary {
    margin: 0;
  }

  .chips {
    margin-top: 1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }

  .chip {
    font-size: 0.8rem;
    padding: 0.35rem 0.6rem;
    border-radius: 999px;
    background: #e9edff;
  }
</style>
