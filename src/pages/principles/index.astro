---
import BaseLayout from '@layouts/BaseLayout.astro';
import MainNav from '@components/MainNav.astro';
import PrincipleCard from '@components/PrincipleCard.astro';
import { principles } from '@data/principles';

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/principles', label: 'Principles' }
];
---

<BaseLayout
  seo={{
    title: 'Static UX Principles | Astro 2026',
    description: 'A collection of 151 prerendered pages with animated navigation and scalable Astro architecture.',
    image: '/social-card.svg'
  }}
>
  <MainNav items={navItems} currentPath={Astro.url.pathname} />

  <main class="container listing" transition:name="principles-listing">
    <header>
      <h1>Principles Library</h1>
      <p>
        Astro prerenders <strong>151 static routes</strong> during the build to deliver exceptional speed without giving up dynamic navigation.
      </p>
    </header>

    <div class="grid">
      {principles.map((principle) => <PrincipleCard principle={principle} compact />)}
    </div>
  </main>
</BaseLayout>

<style>
  .listing {
    padding: 1rem 0 3rem;
  }

  h1 {
    margin-bottom: 0.4rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 0.8rem;
  }
</style>
