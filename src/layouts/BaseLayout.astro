---
import { ViewTransitions } from 'astro:transitions';
import type { SeoProps } from '@types/principle';
import '@styles/global.css';

interface Props {
  seo: SeoProps;
}

const {
  seo: {
    title,
    description,
    image = '/social-card.svg'
  }
} = Astro.props;

const absoluteImage = new URL(image, Astro.site ?? 'https://stitch-ux-principles.pages.dev').toString();
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <!-- Basic SEO + Open Graph + Twitter for social sharing previews. -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImage} />
    <!-- ViewTransitions enables animated navigation + transition names between pages. -->
    <ViewTransitions />
  </head>
  <body>
    <slot />
  </body>
</html>
